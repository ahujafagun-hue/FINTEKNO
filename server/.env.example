# =============================================================================
# FINTEKNO API — copy to server/.env or set the same keys in ../.env (root loads both;
# server/.env overrides ../.env for duplicate keys).
# =============================================================================

# --- Server ---
PORT=3001

# --- Postgres (required) ---
# Neon: Project → Connection details → copy string (often includes ?sslmode=require)
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Local Docker (optional): postgresql://fintekno:fintekno@127.0.0.1:5432/fintekno

# SSL for pg: auto for *.neon.tech and sslmode=require; set true for other remote DBs
# DATABASE_SSL=true

# Connection pool tuning (optional)
# PG_POOL_MAX=10
# PG_IDLE_TIMEOUT_MS=30000
# PG_CONNECTION_TIMEOUT_MS=10000

# --- Auth (JWT) ---
JWT_SECRET=replace-with-long-random-string-at-least-16-chars
JWT_EXPIRES_IN=7d

# --- HTTP ---
# Browser origin allowed by CORS (Vite dev server)
CORS_ORIGIN=http://localhost:5173

# Where OAuth providers redirect the user’s browser after login (React app URL)
APP_ORIGIN=http://localhost:5173

# --- Email OTP (nodemailer) ---
# Without SMTP_HOST, codes are printed to the API terminal and /otp/send returns dev: true
# MAIL_FROM=FINTEKNO <noreply@yourdomain.com>
# MAIL_OTP_SUBJECT=Your FINTEKNO verification code
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# --- Resume parsing (optional) ---
# Without OPENAI_API_KEY, keyword heuristics are used after PDF/DOCX text extract
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Google OAuth (Gmail read-only) ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs (Web)
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/oauth/google/callback

# --- LinkedIn OAuth ---
# LinkedIn Developers → app → Auth → Redirect URLs
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_REDIRECT_URI=http://localhost:3001/api/oauth/linkedin/callback
# LINKEDIN_SCOPES=openid profile email
