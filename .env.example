# =============================================================================
# FINTEKNO React + API — environment template
# =============================================================================
#
# The API loads env from this file first, then server/.env (server overrides).
# For a single file at the repo root, copy the variables from server/.env.example
# into this file. For API-only secrets, you can use server/.env instead.
#
# ---------------------------------------------------------------------------
# Frontend (Vite) — required prefix VITE_
# ---------------------------------------------------------------------------

# Empty = browser calls /api on the same origin and Vite proxies to the API (see vite.config.js).
# Set to a full URL only if the API is on another host (e.g. production).
VITE_API_BASE=

# ---------------------------------------------------------------------------
# Backend — same keys as server/.env.example (optional here if you use server/.env)
# ---------------------------------------------------------------------------

# PORT=3001
# DATABASE_URL=
# JWT_SECRET=
# JWT_EXPIRES_IN=7d
# CORS_ORIGIN=http://localhost:5173
# APP_ORIGIN=http://localhost:5173
#
# SMTP / OTP: SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, MAIL_FROM, MAIL_OTP_SUBJECT, SMTP_SECURE
# OAuth: GOOGLE_*, LINKEDIN_*
# OpenAI: OPENAI_API_KEY, OPENAI_MODEL
# Pool: DATABASE_SSL, PG_POOL_MAX, PG_IDLE_TIMEOUT_MS, PG_CONNECTION_TIMEOUT_MS
#
# Full descriptions: see server/.env.example
